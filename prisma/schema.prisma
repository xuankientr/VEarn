// VEarn Platform - Prisma Schema
// A simplified Web2 task-based earning platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum Role {
  ADMIN
  BUSINESS
  CONTRIBUTOR
}

enum TaskStatus {
  DRAFT       // Task created but not published
  OPEN        // Task available for contributors
  IN_PROGRESS // Task claimed by contributor(s)
  SUBMITTED   // Submission pending review
  APPROVED    // Task completed and approved
  REJECTED    // Task submission rejected
  CLOSED      // Task closed (deadline passed or manually closed)
}

enum SubmissionStatus {
  PENDING   // Awaiting review
  APPROVED  // Submission accepted
  REJECTED  // Submission rejected
}

enum PaymentStatus {
  UNPAID  // Payment pending
  PAID    // Payment completed
}

enum TopUpMethod {
  VNPAY
  MOMO
  BANK_TRANSFER
  /// Nạp mô phỏng — chỉ khi PAYMENT_SANDBOX (dev / demo có chủ đích)
  SANDBOX
  /// Stripe Checkout (test/live — https://dashboard.stripe.com/apikeys )
  STRIPE
}

enum TopUpStatus {
  PENDING              // Created, redirect not completed
  AWAITING_CONFIRMATION // Bank transfer — chờ admin xác nhận
  PROCESSING           // Gateway đang xử lý
  COMPLETED
  FAILED
  CANCELLED
}

enum WithdrawalStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum ApplicationStatus {
  PENDING   // Awaiting review
  APPROVED  // Application accepted - contributor can work on task
  REJECTED  // Application rejected
}

// ============================================
// MODELS
// ============================================

/// User account - can be Admin, Business, or Contributor
model User {
  id               String    @id @default(uuid())
  email            String    @unique
  password         String
  name             String
  username         String?   @unique
  avatar           String?
  bio              String?   @db.Text
  phone            String?
  role             Role      @default(CONTRIBUTOR)
  isActive         Boolean   @default(true)
  isVerified       Boolean   @default(false)
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Enhanced Profile Fields
  skills          String[]           // Contributor skills
  portfolioLinks  String[]           // Portfolio/project links
  website         String?
  location        String?
  company         String?            // For business accounts
  socialLinks     Json?              // { github, linkedin, twitter, etc }
  hourlyRate      Float?             // Expected hourly rate (VND)
  availability    String?            // "full-time", "part-time", "freelance"
  /// Số dư ví (Business nạp qua cổng — dùng trả contributor)
  walletBalance   Float              @default(0)

  /// Contributor: thông tin nhận tiền (Admin CK thủ công / VietQR)
  payoutBankBin     String?
  payoutBankCode    String?
  payoutBankName    String?
  payoutAccountNo   String?
  payoutAccountName String?

  // Relations
  createdTasks    Task[]            @relation("TaskCreator")
  assignedTasks   Task[]            @relation("TaskAssignee")
  submissions     Submission[]
  payments        Payment[]
  applications    TaskApplication[]
  notifications   Notification[]
  reviewsGiven    Review[]          @relation("ReviewsGiven")
  reviewsReceived Review[]          @relation("ReviewsReceived")
  savedTasks      SavedTask[]
  taskTemplates   TaskTemplate[]
  taskComments    TaskComment[]
  walletTopUps       WalletTopUp[]
  walletWithdrawals  WalletWithdrawal[]

  @@index([email])
  @@index([role])
  @@index([username])
  @@index([resetToken])
  @@map("users")
}

/// Task - work item created by business, completed by contributors
model Task {
  id           String     @id @default(uuid())
  title        String
  slug         String     @unique
  description  String     @db.Text
  requirements String?    @db.Text
  reward       Float      // VND amount
  deadline     DateTime?
  status       TaskStatus @default(DRAFT)
  maxAssignees Int        @default(1)
  isPublished  Boolean    @default(false)
  isFeatured   Boolean    @default(false)
  category     String?
  skills       String[]   // Required skills
  /// Ảnh minh họa / cover (URL tuyệt đối hoặc đường dẫn như /uploads/...)
  coverImageUrl String?   @db.Text
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Relations
  creator      User              @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  creatorId    String
  assignees    User[]            @relation("TaskAssignee")
  submissions  Submission[]
  applications TaskApplication[]
  reviews      Review[]
  savedBy      SavedTask[]
  comments     TaskComment[]

  @@index([status])
  @@index([creatorId])
  @@index([slug])
  @@index([isPublished, status])
  @@index([deadline])
  @@map("tasks")
}

/// Public discussion thread on a task (Q&A / comments — not the same as Review.comment)
model TaskComment {
  id        String   @id @default(uuid())
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  /// Trả lời trực tiếp một bình luận gốc (một cấp — không lồng sâu)
  parent   TaskComment?  @relation("TaskCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  parentId String?
  replies  TaskComment[] @relation("TaskCommentReplies")

  @@index([taskId, createdAt])
  @@index([parentId])
  @@map("task_comments")
}

/// Submission - work submitted by contributor for a task
model Submission {
  id          String           @id @default(uuid())
  content     String           @db.Text
  links       String[]         // Array of submitted links
  fileUrls    String[]         // Array of file URLs
  status      SubmissionStatus @default(PENDING)
  feedback    String?          @db.Text
  submittedAt DateTime         @default(now())
  reviewedAt  DateTime?

  // Relations
  task          Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId        String
  contributor   User     @relation(fields: [contributorId], references: [id], onDelete: Cascade)
  contributorId String
  payment       Payment?

  @@index([taskId])
  @@index([contributorId])
  @@index([status])
  @@map("submissions")
}

/// Payment - tracks earnings for approved submissions
model Payment {
  id        String        @id @default(uuid())
  amount    Float         // VND amount
  status    PaymentStatus @default(UNPAID)
  note      String?
  /// MANUAL | WALLET | VNPAY | MOMO (ghi nhận kênh thanh toán cho contributor)
  payChannel String?       @default("MANUAL")
  createdAt DateTime      @default(now())
  paidAt    DateTime?

  // Relations
  contributor   User       @relation(fields: [contributorId], references: [id], onDelete: Cascade)
  contributorId String
  submission    Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  submissionId  String     @unique

  @@index([contributorId])
  @@index([status])
  @@map("payments")
}

/// TaskApplication - application from contributor to work on a task
model TaskApplication {
  id             String            @id @default(uuid())
  coverLetter    String            @db.Text // Why they want to work on this task
  portfolioLinks String[]          // Links to previous work
  experience     String?           @db.Text // Relevant experience
  expectedDays   Int?              // How many days they need
  status         ApplicationStatus @default(PENDING)
  feedback       String?           @db.Text // Feedback from business
  appliedAt      DateTime          @default(now())
  reviewedAt     DateTime?

  // Relations
  task        Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId      String
  applicant   User   @relation(fields: [applicantId], references: [id], onDelete: Cascade)
  applicantId String

  @@unique([taskId, applicantId]) // One application per task per user
  @@index([taskId])
  @@index([applicantId])
  @@index([status])
  @@map("task_applications")
}

// ============================================
// NOTIFICATIONS
// ============================================

enum NotificationType {
  APPLICATION_APPROVED   // Your application was approved
  APPLICATION_REJECTED   // Your application was rejected
  SUBMISSION_APPROVED    // Your submission was approved
  SUBMISSION_REJECTED    // Your submission was rejected
  PAYMENT_RECEIVED       // You received payment
  NEW_APPLICATION        // New application for your task (for businesses)
  NEW_SUBMISSION         // New submission for your task (for businesses)
  TASK_ASSIGNED          // You were assigned to a task
  NEW_TASK_COMMENT       // New comment or reply on a task you own or participated in
}

/// Notification - in-app notifications for users
model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String
  message   String
  link      String?          // Optional link to navigate to
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ============================================
// REVIEWS & RATINGS
// ============================================

/// Review - ratings and reviews between users after task completion
model Review {
  id        String   @id @default(uuid())
  rating    Int      // 1-5 stars
  comment   String?  @db.Text
  createdAt DateTime @default(now())

  // Relations - from reviewer to reviewee
  task       Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId     String
  reviewer   User   @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewerId String
  reviewee   User   @relation("ReviewsReceived", fields: [revieweeId], references: [id], onDelete: Cascade)
  revieweeId String

  @@unique([taskId, reviewerId, revieweeId]) // One review per task per pair
  @@index([revieweeId])
  @@index([reviewerId])
  @@index([taskId])
  @@map("reviews")
}

// ============================================
// SAVED TASKS / WATCHLIST
// ============================================

/// SavedTask - bookmarked tasks for users
model SavedTask {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId String

  @@unique([userId, taskId])
  @@index([userId])
  @@map("saved_tasks")
}

// ============================================
// TASK TEMPLATES
// ============================================

/// TaskTemplate - reusable task templates for businesses
model TaskTemplate {
  id           String   @id @default(uuid())
  name         String
  description  String   @db.Text
  requirements String?  @db.Text
  reward       Float?
  maxAssignees Int      @default(1)
  category     String?
  skills       String[]
  isSystem     Boolean  @default(false) // System-provided templates
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  creator   User?   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  creatorId String?

  @@index([creatorId])
  @@index([isSystem])
  @@map("task_templates")
}

// ============================================
// WALLET & PAYMENT GATEWAY (TOP-UP)
// ============================================

/// WalletTopUp — nạp tiền vào ví Business (VNPay / MoMo / CK ngân hàng)
model WalletTopUp {
  id                   String      @id @default(uuid())
  amount               Float       // VND
  method               TopUpMethod
  status               TopUpStatus @default(PENDING)
  /// Mã giao dịch gửi lên cổng (vnp_TxnRef / orderId)
  gatewayOrderRef      String?     @unique
  gatewayTransactionId String?
  gatewayRaw           Json?
  bankTransferNote     String?     @db.Text
  failureReason        String?     @db.Text
  createdAt            DateTime    @default(now())
  completedAt          DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([userId, createdAt])
  @@index([status])
  @@map("wallet_top_ups")
}

/// Rút tiền khỏi ví Business (sandbox: mô phỏng; production: có thể mở rộng CK thật)
model WalletWithdrawal {
  id          String            @id @default(uuid())
  amount      Float
  status      WithdrawalStatus  @default(PENDING)
  note        String?           @db.Text
  createdAt   DateTime          @default(now())
  completedAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([userId, createdAt])
  @@index([status])
  @@map("wallet_withdrawals")
}
