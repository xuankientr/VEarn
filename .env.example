# Mẫu biến môi trường — Next.js / Docker chỉ đọc file .env (hoặc .env.local), KHÔNG đọc .env.example.
# Sao chép: cp .env.example .env rồi chỉnh giá trị thật trong .env

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/vearn?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-key-change-in-production"

# JWT (for API)
JWT_SECRET="your-jwt-secret-key-change-in-production"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe (tuỳ chọn — webhook/API khác; nạp ví /dashboard/wallet dùng chuyển khoản + VietQR)
STRIPE_SECRET_KEY=""
# Tuỳ chọn dev: chạy `pnpm run stripe:listen`, copy secret whsec_... vào đây
# Production: Developers → Webhooks → Add endpoint → URL https://<domain>/api/payments/webhooks/stripe
STRIPE_WEBHOOK_SECRET=""

# VNPay (nạp ví Business) — https://sandbox.vnpayment.vn/apis/docs/huong-dan-tich-hop
VNPAY_TMN_CODE=""
VNPAY_HASH_SECRET=""
# Tuỳ chọn: URL thanh toán (mặc định sandbox)
# VNPAY_PAYMENT_URL="https://sandbox.vnpayment.vn/paymentv2/vpcpay.html"

# MoMo (nạp ví) — https://developers.momo.vn/
MOMO_PARTNER_CODE=""
MOMO_ACCESS_KEY=""
MOMO_SECRET_KEY=""
# Tuỳ chọn
# MOMO_ENDPOINT="https://test-payment.momo.vn/v2/gateway/api/create"
# Sandbox: bỏ qua verify chữ ký IPN nếu lệch (chỉ dev)
# MOMO_IPN_SKIP_VERIFY="true"

# Chuyển khoản ngân hàng (nạp ví — admin xác nhận trong dashboard)
BANK_TRANSFER_BANK_NAME="Ngân hàng TMCP Ngoại Thương Việt Nam"
BANK_TRANSFER_ACCOUNT_NO="1040206299"
BANK_TRANSFER_ACCOUNT_NAME="Trịnh Xuân Kiên"
# Mã BIN Napas 6 số — hiển thị mã QR VietQR trên /dashboard/wallet (tra bảng mã tại vietqr.io)
# Ví dụ: Vietcombank 970436, Techcombank 970407, MB 970422
BANK_TRANSFER_VIETQR_BIN="970436"

# --- Đồ án / demo — ví & rút tiền mô phỏng ---
# Bật để contributor (và business) dùng "Rút tiền (sandbox)" trên /dashboard/wallet.
# Chỉ trừ/ghi số dư trong DB — không chuyển khoản thật. Khuyến nghị cho đồ án/MVP.
PAYMENT_SANDBOX="true"
# Chỉ khi bạn cố tình chạy production với sandbox (không khuyến nghị):
# PAYMENT_SANDBOX_ALLOW_PROD="true"

# Email (Resend) — bắt buộc cho go-live: đặt lại mật khẩu + thông báo giao dịch
# https://resend.com — tạo API key, xác minh domain, gửi từ địa chỉ domain đó
RESEND_API_KEY=""
# Ví dụ: "VEarn <noreply@yourdomain.com>" (domain đã verify trên Resend)
EMAIL_FROM=""

# Bật cảnh báo startup khi thiếu cấu hình thương mại (production)
# COMMERCIAL_MODE=true

# --- Production / go-to-market ---
# Trên production: NEXTAUTH_URL và NEXT_PUBLIC_APP_URL phải là HTTPS (domain thật).
# Sinh secret đủ mạnh (≥32 ký tự), ví dụ: openssl rand -base64 32
# NEXTAUTH_SECRET / JWT_SECRET
# Database: dùng connection pooler (Neon / Supabase / RDS proxy) nếu deploy serverless.
# Kiểm tra sức khỏe: GET /api/health (load balancer).
# Docker: docker build -t vearn .  (image chạy `pnpm start`)
# Bật output standalone trên Linux CI (tuỳ chọn): NEXT_STANDALONE_OUTPUT=true
# Bỏ qua validate env (chỉ debug / một số bước CI build): SKIP_ENV_VALIDATION=true
